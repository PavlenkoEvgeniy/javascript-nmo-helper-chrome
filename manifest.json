{
  "manifest_version": 3,
  "name": "НМО Помощник",
  "version": "1.0",
  "description": "Парсит страницу НМО и генерирует промпт для ИИ-помощника 🩺",
  "permissions": ["activeTab", "clipboardWrite", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
